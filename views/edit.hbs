<p><span> *必填欄位 </span>請輸入你的支出</p>
<form action="/records/{{record._id}}?_method=PUT" method="POST">
    <div class="row g-3 align-items-center">
        <div class="col-auto">
            <label class="col-form-label" for="name">名稱*：</label>
        </div>
        <div class="col-auto">
            <input class="form-control" type="text" placeholder="name" name="name" id="name" value="{{ record.name }}">
        </div>
    </div>
    <div class="row g-3 align-items-center">
        <div class="col-auto">
            <label class="col-form-label" for="date">日期*：</label>
        </div>
        <div class="col-auto">
            <input class="form-control" type="text" placeholder="date" name="date" id="date" value="{{record.date}}">   
        </div>
    </div>
    <div class="row g-3 align-items-center">
        <div class="col-auto">
            <label class="col-form-label" for="category">類別*：</label>
        </div>
        <div class="col-auto">
            <input class="form-control" type="text" placeholder="category" name="category" id="category" value="{{record.category}}">   
        </div>
    </div>
    <div class="row g-3 align-items-center">
        <div class="col-auto">
             <label class="col-form-label" for="amount">金額*：</label>
        </div>
        <div class="col-auto">
            <input class="form-control" type="text" placeholder="amount" name="amount" id="amount" value="{{record.amount}}">
        </div>
    </div>
    <button class="btn btn-outline-dark" type="submit">送出</button>
</form>